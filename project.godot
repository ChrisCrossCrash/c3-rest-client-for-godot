[application]

config/name="C3 REST Client for Godot"
config/description="A lightweight, async `Node` for talking to JSON REST APIs from Godot 4 projects. Await a request, check `response.ok`, and use the parsed body — no signal wiring or manual status-code handling."
config/version="v0.1.0"
run/main_scene="uid://cgutf16q3860s"
config/features=PackedStringArray("4.6", "Forward Plus")

[audio]

driver/enable_input=true

